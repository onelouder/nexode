{
  "name": "nexode-vscode",
  "displayName": "Nexode",
  "publisher": "nexode",
  "description": "VS Code integration for the Nexode daemon.",
  "version": "0.0.1",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=18"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onCommand:nexode.pauseSlot",
    "onCommand:nexode.resumeSlot",
    "onCommand:nexode.moveTask",
    "onCommand:nexode.openSynapseGrid",
    "onCommand:nexode.openKanban",
    "onView:nexodeSlots",
    "onView:nexodeSynapseSidebar"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nexode",
          "title": "Nexode",
          "icon": "resources/nexode-icon.svg"
        }
      ]
    },
    "views": {
      "nexode": [
        {
          "id": "nexodeSlots",
          "name": "Slots"
        },
        {
          "type": "webview",
          "id": "nexodeSynapseSidebar",
          "name": "Synapse Sidebar"
        }
      ]
    },
    "commands": [
      {
        "command": "nexode.pauseSlot",
        "title": "Nexode: Pause Slot"
      },
      {
        "command": "nexode.resumeSlot",
        "title": "Nexode: Resume Slot"
      },
      {
        "command": "nexode.moveTask",
        "title": "Nexode: Move Task"
      },
      {
        "command": "nexode.openSynapseGrid",
        "title": "Nexode: Open Synapse Grid"
      },
      {
        "command": "nexode.openKanban",
        "title": "Nexode: Open Macro Kanban"
      }
    ],
    "configuration": {
      "title": "Nexode",
      "properties": {
        "nexode.daemonHost": {
          "type": "string",
          "default": "localhost",
          "description": "Hostname or IP address for the Nexode daemon gRPC listener."
        },
        "nexode.daemonPort": {
          "type": "number",
          "default": 50051,
          "minimum": 1,
          "maximum": 65535,
          "description": "TCP port for the Nexode daemon gRPC listener."
        }
      }
    }
  },
  "scripts": {
    "build": "node ./esbuild.mjs --target extension",
    "build:webview": "node ./esbuild.mjs --target webview",
    "watch": "node ./esbuild.mjs --target extension --watch",
    "watch:webview": "node ./esbuild.mjs --target webview --watch",
    "check-types": "tsc --noEmit",
    "test": "tsx --test test/**/*.test.ts",
    "vscode:prepublish": "npm run build && npm run build:webview"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.0",
    "@grpc/proto-loader": "^0.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.0"
  }
}
